rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // USERS (readable to signed-in; all writes via backend/Admin SDK only)
    match /users/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // COURSES (readable to signed-in; all writes via backend/Admin SDK only)
    match /courses/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // PROJECTS (readable to signed-in; all writes via backend/Admin SDK only)
    match /projects/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // UPDATES (readable to signed-in; all writes via backend/Admin SDK only)
    match /updates/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // PURCHASE REQUESTS (readable to signed-in; all writes via backend/Admin SDK only)
    match /purchaseRequests/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
